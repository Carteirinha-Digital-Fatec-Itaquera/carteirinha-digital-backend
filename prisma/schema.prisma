generator client {
  provider = "prisma-client-js"
  moduleFormat= "cjs"
}

datasource db {
  provider = "postgresql"
}

model Student {
  ra        String   @id
  course    String
  period    String
  status    String
  name      String
  admission String
  email     String   @unique
  cpf       String   @unique
  rg        String   @unique
  qrcode    String?
  photo     String?
  birthDate DateTime
  dueDate   DateTime
  //inserir possivel valor de lastLogin do tipo DateTime que pode ser null, seria um valor interessante de colocar
  //para aplicar a funcionalizade de firsLogin:
  // lastLogin DateTime? //No caso ficaria como null na criação e na hora do login se o usuário ter esse atributo como null ele redireciona para 
  //as rotas de resetar senha 
  password  String
}

model Secretary {
  id Int @id @default(autoincrement())
  name String 
  email String @unique
  dueDate DateTime //retirar valor
  password String
}