generator client {
  provider = "prisma-client-js"
  moduleFormat= "cjs"
  output   = "../node_modules/.prisma/client"

}

datasource db {
  provider = "postgresql"

}
enum PhotoStatus {
  PENDING
  APPROVED
  REJECTED
}

model Student {
  ra        String   @id
  course    String
  status    String
  name      String
  admission String
  email     String   @unique
  cpf       String   @unique
  qrcode    String?   @unique
  photo     String?
  birthDate DateTime
  dueDate   DateTime
  password  String

  lastLogin DateTime? 

  photoStatus     PhotoStatus   @default(PENDING)
  approvedBy      String?       
  approvedAt      DateTime?
  rejectionReason String?
}


model Secretary {
  id Int @id @default(autoincrement())
  name String 
  email String @unique
  dueDate DateTime //retirar valor
  password String
  birthDate DateTime
  lastLogin DateTime? 
}



model VerificationCode {
  id        Int      @id @default(autoincrement())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)
}
